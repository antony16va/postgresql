		<procedure name="sp_registrar_log" id="fbfc2741-ff10-412a-8e5c-33611668b373" isSystem="false" params_known="n" >
			<string><![CDATA[create function sp_registrar_log 
DECLARE
    v_linea           varchar;
 
BEGIN
 EXECUTE 'set search_path =' ||pi_esquema;
 
 CASE 
  WHEN POSITION(' línea ' in pi_sql_context)>0 THEN 
   v_linea := TRIM(SUBSTRING(pi_sql_context, 
       POSITION(' línea ' in pi_sql_context)+1,
       LENGTH(pi_sql_context)));
       
  WHEN POSITION(' line ' in pi_sql_context)>0 THEN 
   v_linea := TRIM(SUBSTRING(pi_sql_context, 
       POSITION(' line ' in pi_sql_context)+1,
       LENGTH(pi_sql_context)));
       
  ELSE
   v_linea := null;
 END CASE;   
    INSERT INTO tab_log
      (c_objeto,
      d_fecha_error,
      c_sql_error,
      c_sql_text,
   c_sql_context,
      c_linea,
      c_usuario,
      c_mensaje)
    
 VALUES
      (pi_objeto,
       CURRENT_TIMESTAMP,
       pi_sql_error,
       pi_sql_text,
    pi_sql_context,
       v_linea,
       pi_usuario,
       pi_mensaje);
    --COMMIT;
EXCEPTION
      WHEN OTHERS THEN
        RAISE NOTICE 'po_mensaje =>%', SQLERRM;
  
END;
]]></string>
		</procedure>
		<function name="fn_actualizar_no_pagados_proceso_electoral" id="f01ca0d8-0553-49d4-935a-db6299116447" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_actualizar_no_pagados_proceso_electoral(pi_n_proceso_electoral integer)
 RETURNS void
 LANGUAGE plpgsql
AS $function$
BEGIN
EXECUTE 'SET search_path = gemma';
    UPDATE gemma.tab_proceso_electoral tpe
    SET n_cantidad_no_pagado = COALESCE((
            SELECT COUNT(*)
            FROM gemma.tab_miembro_mesa_escrutinio mme
            WHERE mme.n_proceso_electoral = tpe.n_proceso_electoral_pk
              AND mme.n_estado_pago = 0
        ), 0)
    WHERE tpe.n_proceso_electoral_pk = pi_n_proceso_electoral;
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
		</function>
		<function name="fn_actualizar_pagados_proceso_electoral" id="eb4db81b-1794-4991-88e0-f23ce17c828f" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_actualizar_pagados_proceso_electoral(pi_n_proceso_electoral integer)
 RETURNS void
 LANGUAGE plpgsql
AS $function$
BEGIN
EXECUTE 'SET search_path = gemma';
    UPDATE gemma.tab_proceso_electoral tpe
    SET 
        n_cantidad_pagado = COALESCE((
            SELECT COUNT(*)
            FROM gemma.tab_miembro_mesa_escrutinio mme
            WHERE mme.n_proceso_electoral = tpe.n_proceso_electoral_pk
              AND mme.n_estado_pago = 1
        ),0),
        n_cantidad_no_pagado = COALESCE((
            SELECT COUNT(*)
            FROM gemma.tab_miembro_mesa_escrutinio mme
            WHERE mme.n_proceso_electoral = tpe.n_proceso_electoral_pk
              AND mme.n_estado_pago = 0
        ),0)
    WHERE tpe.n_proceso_electoral_pk = pi_n_proceso_electoral;
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
		</function>
		<function name="fn_confirmar_envio_entidad_bancaria" id="c7b1b84d-2e96-48e1-9ae7-f0ff08e0f476" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_confirmar_envio_entidad_bancaria(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer, pi_usuario character varying)
 RETURNS integer
 LANGUAGE plpgsql
AS $function$
DECLARE
    n_miembro_id INTEGER;
    ya_existe INTEGER;
    n_registros_actualizados INTEGER := 0;
    v_hay_registros BOOLEAN := FALSE;
    v_proceso_existe BOOLEAN := FALSE;
    v_codigo_real INTEGER;
BEGIN
    -- Traduce el código de parámetro a código real de tabla
    SELECT CASE pi_n_entidad_bancaria
               WHEN 1 THEN 41
               WHEN 2 THEN 42
               WHEN 3 THEN 43
               WHEN 4 THEN 44
               WHEN 5 THEN 45
               WHEN 6 THEN 6
               WHEN 7 THEN 7
           END
    INTO v_codigo_real;
    -- Verifica si existe el proceso electoral
    SELECT EXISTS (
        SELECT 1
        FROM gemma.tab_miembro_mesa_escrutinio
        WHERE n_proceso_electoral = pi_n_proceso_electoral
    ) INTO v_proceso_existe;
    IF NOT v_proceso_existe THEN 
        RETURN 0;  -- No existe el proceso
    END IF;
    -- Bucle por cada miembro de mesa con el código real
    FOR n_miembro_id IN
        SELECT mme.n_miembro_mesa_escrutinio_pk
        FROM gemma.tab_miembro_mesa_escrutinio mme
        INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
               ON pmm.n_proceso_electoral = mme.n_proceso_electoral
              AND pmm.c_documento_identidad = mme.c_documento_identidad
              AND pmm.n_activo = 1
        WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
          AND pmm.n_entidad_bancaria = v_codigo_real
    LOOP
        v_hay_registros := TRUE;
        SELECT COUNT(*) INTO ya_existe
        FROM gemma.tab_miembro_mesa_escrutinio_seguimiento mmes
        INNER JOIN gemma.tab_miembro_mesa_escrutinio mme  
                ON mme.n_miembro_mesa_escrutinio_pk = mmes.n_miembro_mesa_escrutinio
        WHERE mmes.n_miembro_mesa_escrutinio = n_miembro_id 
          AND mme.n_proceso_electoral = pi_n_proceso_electoral
          AND mmes.n_fase = 3;
        IF ya_existe = 0 THEN
            UPDATE gemma.tab_miembro_mesa_escrutinio
            SET n_envio_01 = 1,
                n_fase = 3,
                c_aud_usuario_modificacion = pi_usuario,
                d_aud_fecha_modificacion = CURRENT_TIMESTAMP
            WHERE n_miembro_mesa_escrutinio_pk = n_miembro_id;
            INSERT INTO gemma.tab_miembro_mesa_escrutinio_seguimiento 
                (n_miembro_mesa_escrutinio, n_fase, c_aud_usuario_creacion)
            VALUES (n_miembro_id, 3, pi_usuario);
            n_registros_actualizados := n_registros_actualizados + 1;
        END IF;
    END LOOP;
    -- Resultado de la operación
    IF n_registros_actualizados > 0 THEN
        RETURN 1;  -- Se hicieron actualizaciones
    ELSIF NOT v_hay_registros THEN
        RETURN 2;  -- No hay datos a procesar aunque el proceso existe
    ELSE
        RETURN 2;  -- Ya estaban procesados
    END IF;
EXCEPTION
    WHEN OTHERS THEN
        RETURN 0;  -- Error inesperado
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_usuario" jt="-1" type="character varying" inOut="1" />
		</function>
		<function name="fn_det_carga_archivo_banco" id="d3858857-f4ee-42af-b8c6-2c9851acc985" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_det_carga_archivo_banco(p_carga_archivo integer)
 RETURNS SETOF record
 LANGUAGE plpgsql
AS $function$
declare
    l_sql text;
begin
    if p_carga_archivo = 1 then
        -- Banco Nación: transaccion, cuenta, importe
        l_sql := $sql$
            select *
            from crosstab(
                $$select n_fila, c_clave, c_valor
                  from gemma.det_carga_archivo
                 where n_carga_archivo = 1
                 order by n_fila, c_clave$$,
                $$values ('transaccion'), ('cuenta'), ('importe') $$
            ) AS ct (
                n_fila int,
				transaccion text,
                cuenta text,
                importe text 
            )
        $sql$;
    else
        raise exception  'Codigo de Banco % no esta registrado.', p_carga_archivo;
    end if;
    return QUERY execute l_sql;
end
$function$
;]]></string>
			<input_param name="p_carga_archivo" jt="-1" type="integer" inOut="1" />
		</function>
		<function name="fn_filacolumna" id="279e4427-988d-4a31-b0a6-1fa366481dc4" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_filacolumna(esquema character varying, tabla character varying, rowc character varying, colc character varying, cellc character varying, celldatatype character varying, idtipoarchivo integer)
 RETURNS character varying
 LANGUAGE plpgsql
AS $function$
declare
    dynsql1 varchar;
    dynsql2 varchar;
    columnlist varchar;
begin
    -- 1. lista de columnas.
    dynsql1 = 'select string_agg(distinct ''''||'||colc||'||'' '||celldatatype||''','','' order by ''''||'||colc||'||'' '||celldatatype||''') from '||esquema||'.'||tabla||' where n_carga_archivo='||idtipoarchivo||' and n_activo = 1;';
    execute dynsql1 into columnlist;
    -- 2. configura consulta 
    dynsql2 = 'select * from public.crosstab (
 ''select '||rowc||','||colc||','||cellc||' from '||esquema||'.'||tabla||' where n_carga_archivo='||idtipoarchivo||' and n_activo = 1 group by n_fila, c_clave, c_valor order by 1'',
 ''select distinct '||colc||' from '||esquema||'.'||tabla||' where n_carga_archivo='||idtipoarchivo||' and n_activo = 1 order by 1''
 )
 as newtable (
 '||rowc||' varchar,'||columnlist||'
 );';
    return dynsql2;
end
$function$
;]]></string>
			<input_param name="esquema" jt="-1" type="character varying" inOut="1" />
			<input_param name="tabla" jt="-1" type="character varying" inOut="1" />
			<input_param name="rowc" jt="-1" type="character varying" inOut="1" />
			<input_param name="colc" jt="-1" type="character varying" inOut="1" />
			<input_param name="cellc" jt="-1" type="character varying" inOut="1" />
			<input_param name="celldatatype" jt="-1" type="character varying" inOut="1" />
			<input_param name="idtipoarchivo" jt="-1" type="integer" inOut="1" />
		</function>
		<function name="fn_filacolumna_espacios" id="35eff9d6-4b06-4cee-ac06-de3bbaa8eb82" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_filacolumna_espacios(esquema character varying, tabla character varying, rowc character varying, colc character varying, cellc character varying, celldatatype character varying, idtipoarchivo integer)
 RETURNS character varying
 LANGUAGE plpgsql
AS $function$
-- Esta funcion se usa cuando los nombres de los campos contengan espacio en blanco. Ejemplo: CODIGO USUARIO, TIPO DOCUMENTO
DECLARE
    dynsql1 text;
    dynsql2 text;
    columnlist text;
BEGIN
    -- 1. Obtener lista de columnas
    dynsql1 := format(
        $$SELECT string_agg('"' || c_clave || '" %s', ',' ORDER BY c_clave)
          FROM (
            SELECT DISTINCT c_clave
              FROM %I.%I
             WHERE n_carga_archivo = %s AND n_activo = 1
          ) sub;$$,
        celldatatype, esquema, tabla, idtipoarchivo
    );
    EXECUTE dynsql1 INTO columnlist;
    -- Validar si se obtuvo columnas válidas
    IF columnlist IS NULL OR trim(columnlist) = '' THEN
        RETURN NULL;
    END IF;
    -- 2. Construir sentencia del crosstab
    dynsql2 := format(
        $$SELECT * FROM public.crosstab(
            'SELECT %I, %I, %I FROM %I.%I WHERE n_carga_archivo = %s AND n_activo = 1 GROUP BY %I, %I, %I ORDER BY 1',
            'SELECT DISTINCT %I FROM %I.%I WHERE n_carga_archivo = %s AND n_activo = 1 ORDER BY 1'
        ) AS newtable (
            %I varchar,
            %s
        );$$,
        rowc, colc, cellc,
        esquema, tabla, idtipoarchivo,
        rowc, colc, cellc,
        colc, esquema, tabla, idtipoarchivo,
        rowc, columnlist
    );
    RETURN dynsql2;
END;
$function$
;]]></string>
			<input_param name="esquema" jt="-1" type="character varying" inOut="1" />
			<input_param name="tabla" jt="-1" type="character varying" inOut="1" />
			<input_param name="rowc" jt="-1" type="character varying" inOut="1" />
			<input_param name="colc" jt="-1" type="character varying" inOut="1" />
			<input_param name="cellc" jt="-1" type="character varying" inOut="1" />
			<input_param name="celldatatype" jt="-1" type="character varying" inOut="1" />
			<input_param name="idtipoarchivo" jt="-1" type="integer" inOut="1" />
		</function>
		<function name="fn_listado_entidad_bancaria_1" id="656cbaeb-9251-4b6a-a792-9267bf14bea1" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_1(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, transaccion text, num_cuenta text, importe text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del Banco NACION */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        '061' AS transaccion,
        RIGHT(pmm.c_numero_cuenta, 10) AS num_cuenta,
		LPAD(CAST(COALESCE(null, 120) * 100 AS TEXT), 15, '0') AS importe
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = CASE 
                                      WHEN pi_n_entidad_bancaria = 1 THEN 41 
                                      ELSE pi_n_entidad_bancaria
                                   END
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="transaccion" jt="-1" type="text" inOut="3" />
			<input_param name="num_cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="importe" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_entidad_bancaria_2" id="95eb9d9d-56a3-4897-8c98-993d52ee377e" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_2(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, doi_tipo text, doi_numero text, tipo_abono text, cuenta text, nombre text, importe text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del Banco BBVA */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        'L' AS doi_tipo,
        mme.c_documento_identidad::text AS doi_numero,
        'P' AS tipo_abono,
		LEFT(pmm.c_numero_cuenta::text, 8) || '00' || RIGHT(pmm.c_numero_cuenta::text, 10) AS cuenta,
		REPLACE(REPLACE(mme.c_apellido_paterno::text || ' ' || mme.c_apellido_materno::text || ' ' || mme.c_nombres::text,'Ñ', 'N'), 'ñ', 'n') AS nombre,
		LPAD(TO_CHAR(COALESCE(null, 120), 'FM9999999999990.00'), 6, '0') AS importe
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = CASE 
                                      WHEN pi_n_entidad_bancaria = 2 THEN 42
                                      ELSE pi_n_entidad_bancaria
                                   END
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="doi_tipo" jt="-1" type="text" inOut="3" />
			<input_param name="doi_numero" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_abono" jt="-1" type="text" inOut="3" />
			<input_param name="cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="nombre" jt="-1" type="text" inOut="3" />
			<input_param name="importe" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_entidad_bancaria_3" id="2b28d6d5-e90f-4848-8be5-3f1825fa4158" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_3(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, tipo_registro text, tipo_cuenta_abono text, cuenta_abono text, tipo_doc text, nro_doc text, nombre text, moneda text, importe text, idc text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del Banco BCP */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        'A' AS tipo_registro,
        'A' AS tipo_cuenta_abono,
        pmm.c_numero_cuenta::text AS cuenta_abono,
        '1' AS tipo_doc,
        mme.c_documento_identidad::text AS nro_doc,
		REPLACE(REPLACE(mme.c_apellido_paterno::text || ' ' || mme.c_apellido_materno::text || ' ' || mme.c_nombres::text,'Ñ', 'N'), 'ñ', 'n') AS nombre,
        'S' AS moneda,
		LPAD(TO_CHAR(COALESCE(null, 120), 'FM9999999999990.00'), 17, '0') AS importe,
        'S' AS idc
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = CASE 
                                      WHEN pi_n_entidad_bancaria = 3 THEN 43
                                      ELSE pi_n_entidad_bancaria
                                   END
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="tipo_registro" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_cuenta_abono" jt="-1" type="text" inOut="3" />
			<input_param name="cuenta_abono" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_doc" jt="-1" type="text" inOut="3" />
			<input_param name="nro_doc" jt="-1" type="text" inOut="3" />
			<input_param name="nombre" jt="-1" type="text" inOut="3" />
			<input_param name="moneda" jt="-1" type="text" inOut="3" />
			<input_param name="importe" jt="-1" type="text" inOut="3" />
			<input_param name="idc" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_entidad_bancaria_4" id="1cd4b01e-4cc8-4e6d-91ba-8c68dc1026ab" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_4(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, codigo_de_entidad text, abono text, importe text, banco text, tipo_abono text, tipo_cuenta text, moneda_cuenta text, tienda text, num_cuenta text, tipo_persona text, tipo_doc text, nro_doc text, nombre text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del Banco INTERBANK */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        mme.c_documento_identidad::text AS codigo_de_entidad,	
        '01' AS abono,		
		LPAD(TO_CHAR(COALESCE(null, 120), 'FM9999999999990.00'), 6, '0') AS importe,
        '' AS banco,	
        '09' AS tipo_abono,	
        '002' AS tipo_cuenta,	
        '01' AS moneda_cuenta,	
        LEFT(pmm.c_numero_cuenta::text , 3) AS tienda,	
        RIGHT(pmm.c_numero_cuenta::text, 10) AS num_cuenta,
        'P' AS tipo_persona,	
        '01' AS tipo_doc,	
        mme.c_documento_identidad::text AS nro_doc,	
		REPLACE(REPLACE(REPLACE(mme.c_apellido_paterno::text || ';' || mme.c_apellido_materno::text || ';' || mme.c_nombres::text, ' ', ';'),'Ñ', 'N'),'ñ', 'n') AS nombre
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = CASE 
                                      WHEN pi_n_entidad_bancaria = 4 THEN 44
                                      ELSE pi_n_entidad_bancaria
                                   END
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="codigo_de_entidad" jt="-1" type="text" inOut="3" />
			<input_param name="abono" jt="-1" type="text" inOut="3" />
			<input_param name="importe" jt="-1" type="text" inOut="3" />
			<input_param name="banco" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_abono" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="moneda_cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="tienda" jt="-1" type="text" inOut="3" />
			<input_param name="num_cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_persona" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_doc" jt="-1" type="text" inOut="3" />
			<input_param name="nro_doc" jt="-1" type="text" inOut="3" />
			<input_param name="nombre" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_entidad_bancaria_5" id="83b97d6e-bb0d-454b-baba-b66b27879aaa" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_5(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, codigo_empleado text, nombre_empleado text, concepto text, fecha_pago text, monto_pagar text, forma_pago text, codigo_oficina text, codigo_cuenta text, itf text, documento_identidad text, cci text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del Banco SCOTIABANK */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        mme.c_documento_identidad::text AS codigo_empleado,	
		REPLACE(REPLACE(mme.c_apellido_paterno::text || ' ' || mme.c_apellido_materno::text || ' ' || mme.c_nombres::text,'Ñ', 'N'), 'ñ', 'n') AS nombre_empleado,				
        'PAGO AL MM' AS concepto,	
        TO_CHAR(CURRENT_DATE + INTERVAL '1 day', 'YYYY-MM-DD') AS fecha_pago,
		LPAD(TO_CHAR(COALESCE(null, 120), 'FM9999999999990.00'), 6, '0') AS monto_pagar,
        '3' AS forma_pago,	
        LEFT(pmm.c_numero_cuenta::text , 3) AS codigo_oficina,	
        RIGHT(pmm.c_numero_cuenta::text, 7) AS codigo_cuenta,
        '' AS itf,	
        mme.c_documento_identidad::text AS documento_identidad,	
        '' AS cci
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = CASE 
                                      WHEN pi_n_entidad_bancaria = 5 THEN 45
                                      ELSE pi_n_entidad_bancaria
                                   END
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="codigo_empleado" jt="-1" type="text" inOut="3" />
			<input_param name="nombre_empleado" jt="-1" type="text" inOut="3" />
			<input_param name="concepto" jt="-1" type="text" inOut="3" />
			<input_param name="fecha_pago" jt="-1" type="text" inOut="3" />
			<input_param name="monto_pagar" jt="-1" type="text" inOut="3" />
			<input_param name="forma_pago" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_oficina" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_cuenta" jt="-1" type="text" inOut="3" />
			<input_param name="itf" jt="-1" type="text" inOut="3" />
			<input_param name="documento_identidad" jt="-1" type="text" inOut="3" />
			<input_param name="cci" jt="-1" type="text" inOut="3" />
