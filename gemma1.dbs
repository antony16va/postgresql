		<view name="vw_miembros_mesa_pago" >
			<view_script><![CDATA[CREATE OR REPLACE VIEW ${view} AS SELECT tpe.n_proceso_electoral_pk,
    tpe.c_nombre AS c_proceso_electoral,
    tpe.d_fecha_convocatoria,
    dce.c_nombre AS c_tipo_documento,
    tmme.c_documento_identidad,
    concat_ws(' '::text, tmme.c_apellido_paterno, tmme.c_apellido_materno, tmme.c_nombres) AS c_apellidos_nombres,
    dce2.c_nombre AS c_cargo,
    dce3.c_nombre AS c_entidad_bancaria,
    dce4.c_nombre AS c_estado_pago,
    dce5.c_nombre AS c_estado_pago_programado,
    tmme.d_fecha_pago
   FROM (((((((tab_miembro_mesa_escrutinio tmme
     JOIN tab_medio_pago_miembro_mesa tmpmm ON (((tmpmm.n_miembro_mesa_escrutinio = tmme.n_miembro_mesa_escrutinio_pk) AND (tmpmm.n_activo = 1))))
     JOIN tab_proceso_electoral tpe ON (((tpe.n_proceso_electoral_pk = tmpmm.n_proceso_electoral) AND (tpe.n_activo = 1))))
     JOIN det_catalogo_estructura dce ON (((dce.n_codigo = tmme.n_tipo_documento) AND ((dce.c_columna)::text = 'n_tipo_documento_identidad'::text))))
     JOIN det_catalogo_estructura dce2 ON (((dce2.n_codigo = tmme.n_cargo) AND ((dce2.c_columna)::text = 'n_cargo_miembro_mesa'::text) AND (dce2.n_activo = 1))))
     JOIN det_catalogo_estructura dce3 ON ((((dce3.c_codigo)::integer = (tmpmm.n_entidad_bancaria)::integer) AND ((dce3.c_columna)::text = 'n_entidad_bancaria'::text) AND (dce3.n_activo = 1))))
     JOIN det_catalogo_estructura dce4 ON (((dce4.n_codigo = tmme.n_estado_pago) AND ((dce4.c_columna)::text = 'n_estado_pago'::text) AND (dce4.n_activo = 1))))
     JOIN det_catalogo_estructura dce5 ON (((dce5.n_codigo = tmme.n_estado_pago_programado) AND ((dce5.c_columna)::text = 'n_estado_pago_programado'::text) AND (dce5.n_activo = 1))))
  WHERE (tmme.n_activo = 1)]]></view_script>
			<column name="n_proceso_electoral_pk" type="integer" />
			<column name="c_proceso_electoral" type="varchar" />
			<column name="d_fecha_convocatoria" type="date" />
			<column name="c_tipo_documento" type="varchar" />
			<column name="c_documento_identidad" type="varchar" />
			<column name="c_apellidos_nombres" type="text" />
			<column name="c_cargo" type="varchar" />
			<column name="c_entidad_bancaria" type="varchar" />
			<column name="c_estado_pago" type="varchar" />
			<column name="c_estado_pago_programado" type="varchar" />
			<column name="d_fecha_pago" type="date" />
		</view>
