		<sequence name="sq_tab_miembro_mesa_escrutinio_trazabilidad_pk" options="START WITH 1 INCREMENT BY 1" />
		<sequence name="sq_tab_pago_miembro_mesa_trazabilidad_pk" options="START WITH 1 INCREMENT BY 1" />
		<sequence name="sq_tab_proceso_electoral_pk" options="START WITH 1 INCREMENT BY 1 MAXVALUE 999999999999999" />
		<sequence name="sq_tab_ubigeo_proceso_electoral_pk" options="START WITH 1 INCREMENT BY 1 MAXVALUE 999999999999999" />
		<procedure name="sp_actualizar_pago_miembro_mesa_escrutinio" id="b94b0ff8-d85c-439d-b4a5-0e9907c3eede" isSystem="false" params_known="n" >
			<string><![CDATA[create function sp_actualizar_pago_miembro_mesa_escrutinio 
DECLARE
    v_documento_identidad VARCHAR(20);
    v_miembro_mesa_escrutinio INTEGER;
    v_envio_01 INT;
    v_recepcionado_01 INT;
    v_envio_02 INT;
    v_recepcionado_02 INT;
    v_codigo_real INTEGER;
    v_proceso_electoral INTEGER;
BEGIN
    v_documento_identidad := pi_documento_identidad;
    -- 📌 Si enviaron el número de desembolso, recupero el proceso electoral y fijo entidad bancaria en 7
    IF pi_numero_desembolso IS NOT NULL THEN
        SELECT tpe.n_proceso_electoral_pk
        INTO v_proceso_electoral
        FROM tab_proceso_electoral tpe
        WHERE tpe.c_numero_desembolso = pi_numero_desembolso
        LIMIT 1;
        IF v_proceso_electoral IS NULL THEN
            RAISE EXCEPTION 'No se encontró proceso electoral con número de desembolso %', pi_numero_desembolso;
        END IF;
        pi_proceso_electoral := v_proceso_electoral;
        pi_entidad_bancaria := 7;  -- se fuerza a 7
    ELSE
        v_proceso_electoral := pi_proceso_electoral;
    END IF;
    -- Traducir código de parámetro a código real
    SELECT CASE pi_entidad_bancaria
               WHEN 1 THEN 41
               WHEN 2 THEN 42
               WHEN 3 THEN 43
               WHEN 4 THEN 44
               WHEN 5 THEN 45
               WHEN 6 THEN 6
               WHEN 7 THEN 7
           END
    INTO v_codigo_real;
    -- Buscar datos del miembro de mesa
    SELECT mme.n_miembro_mesa_escrutinio_pk,
           mme.n_envio_01,
           mme.n_recepcionado_01,
           mme.n_envio_02,
           mme.n_recepcionado_02
    INTO v_miembro_mesa_escrutinio, v_envio_01, v_recepcionado_01, v_envio_02, v_recepcionado_02
    FROM gemma.tab_miembro_mesa_escrutinio mme
    WHERE mme.c_documento_identidad = v_documento_identidad
      AND mme.n_proceso_electoral = v_proceso_electoral
    LIMIT 1;
    IF NOT FOUND THEN
        RAISE NOTICE 'No se encontró miembro de mesa con documento % en el proceso electoral %.', 
                     v_documento_identidad, v_proceso_electoral;
        RETURN;
    END IF;
    -- Depuración
    RAISE NOTICE 'Datos obtenidos: envio_01=%, recep_01=%, tipo_op=%, entidad_bancaria=%, codigo_real=%', 
                 v_envio_01, v_recepcionado_01, pi_tipo_operacion, pi_entidad_bancaria, v_codigo_real;
    -- Caso 1: PAGADO
    IF v_envio_01 = 1 AND v_recepcionado_01 IS NULL AND pi_tipo_operacion = 1 THEN
        UPDATE gemma.tab_miembro_mesa_escrutinio
        SET n_recepcionado_01 = 1,
            n_estado_pago = 1,
            n_fase = 4,
            d_fecha_pago = CASE 
                               WHEN pi_entidad_bancaria = 7 
                               THEN pi_fecha_pago
                               ELSE current_timestamp
                           END
        WHERE n_miembro_mesa_escrutinio_pk = v_miembro_mesa_escrutinio;
        RAISE NOTICE 'Actualizado a PAGADO.';
        RETURN;
    -- Caso 2: NO PAGADO
    ELSIF v_envio_01 = 1 AND v_recepcionado_01 IS NULL AND pi_tipo_operacion = 0 THEN
        UPDATE gemma.tab_miembro_mesa_escrutinio
        SET n_recepcionado_01 = 0
        WHERE n_miembro_mesa_escrutinio_pk = v_miembro_mesa_escrutinio;
        RAISE NOTICE 'Actualizado a NO PAGADO.';
        -- Resetear datos si quedó como "No Pagado"
        UPDATE gemma.tab_miembro_mesa_escrutinio 
        SET n_recepcionado_01 = NULL,
            n_fase = 3, --estaba null --pasamos a 3 --por ahora luego quitar --29-08-2025
            n_envio_01 = 1 --estaba null --pasamos a 1 --por ahora luego quitar --29-08-2025
        WHERE n_recepcionado_01 = 0
          AND n_proceso_electoral = v_proceso_electoral
          AND n_miembro_mesa_escrutinio_pk = v_miembro_mesa_escrutinio;
        -- Actualizar datos en tab_medio_pago_miembro_mesa
        UPDATE gemma.tab_medio_pago_miembro_mesa 
        SET n_entidad_bancaria = 7, --pi_entidad_bancaria,
            n_modalidad_pago = 2
        WHERE n_proceso_electoral = v_proceso_electoral
          AND n_miembro_mesa_escrutinio = v_miembro_mesa_escrutinio;
        RETURN;
    ELSE
        RAISE NOTICE 'No se realizó ninguna actualización.';
    END IF;
END;
]]></string>
		</procedure>
		<procedure name="sp_confirmar_envio_entidad_bancaria_1" id="32eb0e54-2fb1-4e0d-9671-7717eaaacf19" isSystem="false" params_known="n" >
			<string><![CDATA[create function sp_confirmar_envio_entidad_bancaria_1 
DECLARE
    n_miembro_id INTEGER;
    ya_existe INTEGER;
BEGIN
 
  -- Inicializar
    po_status := 1;
    po_mensaje := 'Operación realizada correctamente.';
    FOR n_miembro_id IN
        SELECT mme.n_miembro_mesa_escrutinio_pk
        FROM gemma.tab_miembro_mesa_escrutinio mme
        INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
            ON pmm.n_proceso_electoral = mme.n_proceso_electoral
            AND pmm.c_documento_identidad = mme.c_documento_identidad
            AND pmm.n_activo = 1
        WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
          AND pmm.n_entidad_bancaria = 41
          AND mme.n_envio_01 IS NULL
    LOOP
 
     -- Validar si ya existe seguimiento con fase = 3
        SELECT COUNT(*) INTO ya_existe
        FROM gemma.tab_miembro_mesa_escrutinio_seguimiento
        WHERE n_miembro_mesa_escrutinio = n_miembro_id
          AND n_fase = 3;
    
    
  IF ya_existe = 0 THEN
            -- Actualizar tabla principal
            UPDATE gemma.tab_miembro_mesa_escrutinio
            SET n_envio_01 = 1,
                n_fase = 3,
                c_aud_usuario_modificacion = pi_usuario,
                d_aud_fecha_modificacion = CURRENT_TIMESTAMP
            WHERE n_miembro_mesa_escrutinio_pk = n_miembro_id;
            -- Insertar seguimiento
            INSERT INTO gemma.tab_miembro_mesa_escrutinio_seguimiento (
                n_miembro_mesa_escrutinio,
                n_fase,
                n_activo,
                c_aud_usuario_creacion
            ) VALUES (
                n_miembro_id,
                3,
                1,
                pi_usuario
            );
        END IF;
 END LOOP;
  
EXCEPTION
    WHEN OTHERS THEN
        po_status := 2;
        po_mensaje := 'Error al procesar: ' || SQLERRM;      
END;
]]></string>
		</procedure>
		<procedure name="sp_generar_formatos_entidad_bancaria" id="1577f55f-680d-4ec3-bfb1-1f38d9b64993" isSystem="false" params_known="n" >
			<string><![CDATA[create function sp_generar_formatos_entidad_bancaria 
/************************************************************************************************************/
/* Procedimiento que carga datos de plantilla excel que contiene los coordinadores de local de votacion  */
/* Elaborado por: Dilmer Palomino Pardo Fecha de creación: 07/05/2025                */
/* CALL gemma.sp_generar_formatos_entidad_bancaria('gemma','dpalomino',1,0, '');            */
/* pi_n_carga_archivo:                      */
/*       1 Banco Nacion                  */ 
/*       2 BBVA                    */
/*       3 BCP                    */ 
/*       4 Interbank                   */
/*       5 Scotiabank                  */
/************************************************************************************************************/
DECLARE
    sQueryCrea  text;
    v_context   text;
    v_msg       text;
    VC_PUBLIC   text := 'public';
    VN_CARGA_PK integer;
BEGIN
    -- Establecer search_path
    EXECUTE format('SET search_path TO %I, %I', pi_esquema, VC_PUBLIC);
    -- Validar carga activa
    SELECT n_carga_archivo_pk INTO VN_CARGA_PK
    FROM cab_carga_archivo
    WHERE n_carga_archivo_pk = pi_n_carga_archivo
      AND n_activo = 1;
    IF VN_CARGA_PK IS NULL THEN
        po_resultado := -1;
        po_mensaje := 'No se encontró la carga activa con el ID proporcionado';
        RETURN;
    END IF;
 IF pi_n_carga_archivo <=4 THEN
     -- Obtener SQL dinámico para crear la vista
     SELECT fn_filacolumna(
         pi_esquema,
         'det_carga_archivo',
         'n_fila',
         'c_clave',
         'c_valor',
         'text',
         VN_CARGA_PK
     ) INTO sQueryCrea;
 ELSEIF  pi_n_carga_archivo = 5 THEN
  SELECT fn_filacolumna_v2(
         pi_esquema,
         'det_carga_archivo',
         'n_fila',
         'c_clave',
         'c_valor',
         'text',
         VN_CARGA_PK
     ) INTO sQueryCrea;
 END IF;
 -- Validación: evitar ejecución si el SQL es nulo o sospechosamente incorrecto
 IF sQueryCrea IS NULL OR trim(sQueryCrea) = '' OR position('SELECT' in upper(sQueryCrea)) = 0 AND pi_n_carga_archivo <=4 THEN
  po_resultado := -1;
     po_mensaje := 'La función fn_filacolumna devolvió un SQL inválido';
     RETURN;
 END IF;
 IF sQueryCrea IS NULL OR trim(sQueryCrea) = '' OR position('SELECT' in upper(sQueryCrea)) = 0 AND pi_n_carga_archivo =5  THEN
  po_resultado := -1;
     po_mensaje := 'La función fn_filacolumna_espacios devolvió un SQL inválido';
     RETURN;
 END IF;
     -- Mostrar consulta generada
     RAISE NOTICE 'Consulta generada: %', sQueryCrea;
  -- BANCO DE LA NACION
 IF pi_n_carga_archivo = 1 THEN
     -- Crear vista con el SQL generado
  BEGIN
         EXECUTE format('CREATE OR REPLACE VIEW %I.vw_formatos_entidad_bancaria_nacion AS %s', pi_esquema, sQueryCrea);
         po_resultado := 1;
         po_mensaje := 'Vista creada correctamente';
     EXCEPTION WHEN OTHERS THEN
         GET STACKED DIAGNOSTICS v_context = PG_EXCEPTION_CONTEXT;
         po_resultado := -1;
         po_mensaje := 'Error al crear la vista: ' || SQLERRM;
         -- Registrar en tabla log
     END;        
 END IF;
 -- BANCO BBVA
 IF pi_n_carga_archivo =2 THEN
     -- Crear vista con el SQL generado
     BEGIN
         EXECUTE format('CREATE OR REPLACE VIEW %I.vw_formatos_entidad_bancaria_bbva AS %s', pi_esquema, sQueryCrea);
         po_resultado := 1;
         po_mensaje := 'Vista creada correctamente';
     EXCEPTION WHEN OTHERS THEN
         GET STACKED DIAGNOSTICS v_context = PG_EXCEPTION_CONTEXT;
         po_resultado := -1;
         po_mensaje := 'Error al crear la vista: ' || SQLERRM;
         -- Registrar en tabla log
     END;        
 END IF;
 -- BANCO BCP
 IF pi_n_carga_archivo =3 THEN
     -- Crear vista con el SQL generado
     BEGIN
         EXECUTE format('CREATE OR REPLACE VIEW %I.vw_formatos_entidad_bancaria_bcp AS %s', pi_esquema, sQueryCrea);
         po_resultado := 1;
         po_mensaje := 'Vista creada correctamente';
     EXCEPTION WHEN OTHERS THEN
         GET STACKED DIAGNOSTICS v_context = PG_EXCEPTION_CONTEXT;
         po_resultado := -1;
         po_mensaje := 'Error al crear la vista: ' || SQLERRM;
         -- Registrar en tabla log
     END;        
 END IF;
-- BANCO INTERBANK
IF pi_n_carga_archivo =4 THEN
     -- Crear vista con el SQL generado
     BEGIN
         EXECUTE format('CREATE OR REPLACE VIEW %I.vw_formatos_entidad_bancaria_interbank AS %s', pi_esquema, sQueryCrea);
         po_resultado := 1;
         po_mensaje := 'Vista creada correctamente';
     EXCEPTION WHEN OTHERS THEN
         GET STACKED DIAGNOSTICS v_context = PG_EXCEPTION_CONTEXT;
         po_resultado := -1;
         po_mensaje := 'Error al crear la vista: ' || SQLERRM;
         -- Registrar en tabla log
     END;        
 END IF;
-- BANCO SCOTIABANK
IF pi_n_carga_archivo =5 THEN
     -- Crear vista con el SQL generado
     BEGIN
         EXECUTE format('CREATE OR REPLACE VIEW %I.vw_formatos_entidad_bancaria_scotiabank AS %s', pi_esquema, sQueryCrea);
         po_resultado := 1;
         po_mensaje := 'Vista creada correctamente';
     EXCEPTION WHEN OTHERS THEN
         GET STACKED DIAGNOSTICS v_context = PG_EXCEPTION_CONTEXT;
         po_resultado := -1;
         po_mensaje := 'Error al crear la vista: ' || SQLERRM;
         -- Registrar en tabla log
     END;        
 END IF;

END;
]]></string>
		</procedure>
		<procedure name="sp_list_generar_formatos_entidad_bancaria" id="fe5f07c5-ecce-4c39-92c5-f91a8b2b71d1" isSystem="false" params_known="n" >
			<string><![CDATA[create function sp_list_generar_formatos_entidad_bancaria 
