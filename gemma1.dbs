		<function name="fn_listado_entidad_bancaria_6" id="1dd45c3f-fa4e-4569-8ad4-3fa34bddf1be" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_6(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, dni text, nombre text, telefono text)
 LANGUAGE plpgsql
AS $function$
/* Data estructurada para formato del YAPE */
BEGIN
    EXECUTE 'SET search_path = gemma';
    RETURN QUERY
    SELECT
        ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
        mme.c_documento_identidad::text AS dni,	
		REPLACE(REPLACE(mme.c_apellido_paterno::text || ' ' || mme.c_apellido_materno::text || ' ' || mme.c_nombres::text,'Ñ', 'N'), 'ñ', 'n') AS nombre,				
        pmm.n_numero_vinculado::text AS telefono
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = pi_n_entidad_bancaria
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="dni" jt="-1" type="text" inOut="3" />
			<input_param name="nombre" jt="-1" type="text" inOut="3" />
			<input_param name="telefono" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_entidad_bancaria_7" id="11fc71ed-5be0-4ac1-a5a9-13f198a8250c" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria_7(pi_n_proceso_electoral integer, pi_n_entidad_bancaria integer)
 RETURNS TABLE(codigo_banco text, codigo_cliente text, num_registro text, importe_total_soles text, importe_total_dolares text, fecha_proceso text, tipo_registro text, espacios_blanco_cab text, codigo_credito text, num_desembolso text, situacion_desembolso text, clave text, codigo_moneda text, tipo_persona text, nombre_beneficiario text, tipo_documento_beneficiario text, num_documento_beneficiario text, nombre_representante text, tipo_documento_representante text, num_documento_representante text, importe_desembolso text, fecha_caducidad text, agencia_cobro text, tipo_datos text, codigo_interbancario text, cuenta_cliente text, orden_pago text, fecha_activacion text, espacios_blanco_det text)
 LANGUAGE plpgsql
AS $function$
DECLARE
    v_n_cantidad_detalle INTEGER;
/* Data estructurada para formato del PRESENCIAL */
BEGIN
    EXECUTE 'SET search_path = gemma';
    -- Verificar si el DETALLE devuelve registros
    SELECT COUNT(*)
    INTO v_n_cantidad_detalle
    FROM gemma.tab_miembro_mesa_escrutinio mme
    INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
        ON pmm.n_proceso_electoral = mme.n_proceso_electoral
        AND pmm.c_documento_identidad = mme.c_documento_identidad
        AND pmm.n_activo = 1
    WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
      AND pmm.n_entidad_bancaria = pi_n_entidad_bancaria
      AND pmm.n_billetera_digital = 0
	  and mme.n_estado_pago_programado = 0
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
    IF v_n_cantidad_detalle > 0 THEN
        RETURN QUERY
        -- CABECERA
        SELECT
			RPAD('018', 4, ' ')codigo_banco,
            '0180101' AS codigo_cliente,
            LPAD(v_n_cantidad_detalle::text, 7, '0') AS num_registro,
            LPAD((SUM(COALESCE(120,0)) * 100)::text, 15, '0') AS importe_total_soles,
            '000000000000000' AS importe_total_dolares,
            --TO_CHAR(CURRENT_DATE, 'YYYYMMDD') AS fecha_proceso,
			TO_CHAR(CURRENT_DATE + INTERVAL '1 day', 'YYYYMMDD') AS fecha_proceso,
            '01' AS tipo_registro,
            RPAD('', 226, ' ') AS espacios_blanco_cab,
            NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text,
            NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text,
            NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text,
            NULL::text, NULL::text, NULL::text
        FROM gemma.tab_miembro_mesa_escrutinio mme
        INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
            ON pmm.n_proceso_electoral = mme.n_proceso_electoral
            AND pmm.c_documento_identidad = mme.c_documento_identidad
            AND pmm.n_activo = 1
        WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
          AND pmm.n_entidad_bancaria = pi_n_entidad_bancaria
		  and mme.n_estado_pago_programado = 0
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        )
        UNION ALL
        -- DETALLE
        SELECT
            NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text, NULL::text,
            '0000' || mme.c_documento_identidad::text,
            '001', '01',
            RIGHT(mme.c_documento_identidad::text, 4),
            '1', '1',
			RPAD(LEFT(REPLACE(REPLACE(CONCAT_WS(' ', mme.c_apellido_paterno, mme.c_apellido_materno, mme.c_nombres),'Ñ', 'N'),'ñ', 'n'),60),60,' '),
            '010000000',
            LPAD(mme.c_documento_identidad, 8, '0'),
            RPAD('', 60, ' '),
            '  ',
            '               ',
            LPAD((COALESCE(120, 0) * 100)::text, 15, '0'),
            TO_CHAR(CURRENT_DATE + INTERVAL '1 day', 'YYYYMMDD'),
            '0000', '01',
            '00000000000000000000',
            '00000282928',
            '000000000001',
            --TO_CHAR(CURRENT_DATE, 'YYYYMMDD'),
			TO_CHAR(CURRENT_DATE + INTERVAL '1 day', 'YYYYMMDD'),
            RPAD('', 23, ' ')
        FROM gemma.tab_miembro_mesa_escrutinio mme
        INNER JOIN gemma.tab_medio_pago_miembro_mesa pmm
            ON pmm.n_proceso_electoral = mme.n_proceso_electoral
            AND pmm.c_documento_identidad = mme.c_documento_identidad
            AND pmm.n_activo = 1
        WHERE mme.n_proceso_electoral = pi_n_proceso_electoral
          AND pmm.n_entidad_bancaria = pi_n_entidad_bancaria
		  and mme.n_estado_pago_programado = 0
		AND (
	        -- No enviado
	        mme.n_envio_01 IS NULL 
	        -- Enviado pero no recepcionado
	        OR (mme.n_envio_01 IS NOT NULL AND mme.n_recepcionado_01 IS NULL) 
        );
    END IF;
END;
$function$
;]]></string>
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_entidad_bancaria" jt="-1" type="integer" inOut="1" />
			<input_param name="codigo_banco" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_cliente" jt="-1" type="text" inOut="3" />
			<input_param name="num_registro" jt="-1" type="text" inOut="3" />
			<input_param name="importe_total_soles" jt="-1" type="text" inOut="3" />
			<input_param name="importe_total_dolares" jt="-1" type="text" inOut="3" />
			<input_param name="fecha_proceso" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_registro" jt="-1" type="text" inOut="3" />
			<input_param name="espacios_blanco_cab" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_credito" jt="-1" type="text" inOut="3" />
			<input_param name="num_desembolso" jt="-1" type="text" inOut="3" />
			<input_param name="situacion_desembolso" jt="-1" type="text" inOut="3" />
			<input_param name="clave" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_moneda" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_persona" jt="-1" type="text" inOut="3" />
			<input_param name="nombre_beneficiario" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_documento_beneficiario" jt="-1" type="text" inOut="3" />
			<input_param name="num_documento_beneficiario" jt="-1" type="text" inOut="3" />
			<input_param name="nombre_representante" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_documento_representante" jt="-1" type="text" inOut="3" />
			<input_param name="num_documento_representante" jt="-1" type="text" inOut="3" />
			<input_param name="importe_desembolso" jt="-1" type="text" inOut="3" />
			<input_param name="fecha_caducidad" jt="-1" type="text" inOut="3" />
			<input_param name="agencia_cobro" jt="-1" type="text" inOut="3" />
			<input_param name="tipo_datos" jt="-1" type="text" inOut="3" />
			<input_param name="codigo_interbancario" jt="-1" type="text" inOut="3" />
			<input_param name="cuenta_cliente" jt="-1" type="text" inOut="3" />
			<input_param name="orden_pago" jt="-1" type="text" inOut="3" />
			<input_param name="fecha_activacion" jt="-1" type="text" inOut="3" />
			<input_param name="espacios_blanco_det" jt="-1" type="text" inOut="3" />
		</function>
		<function name="fn_listado_miembros_mesa" id="bba75957-9543-49a9-8b06-ec7bd7f7be8a" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_listado_miembros_mesa(pi_n_banco integer, pi_n_proceso_electoral integer)
 RETURNS TABLE(n_miembro_mesa_escrutinio_paginado_pk integer, n_miembro_mesa_escrutinio_pk integer, n_proceso_electoral integer, c_mesa character varying, n_tipo_documento integer, c_documento_identidad character varying, c_apellido_paterno character varying, c_apellido_materno character varying, c_nombres character varying, n_cargo integer, n_ubigeo integer, n_envio_01 integer, n_recepcionado_01 integer, n_envio_02 integer, n_entidad_bancaria integer, n_modalidad_pago integer, c_numero_cuenta character varying, n_billetera_digital integer, n_numero_vinculado character varying, n_activo integer)
 LANGUAGE plpgsql
AS $function$
	BEGIN
		-- CREATE OR REPLACE FUNCTION gemma.fn_listado_entidad_bancaria(pi_esquema character varying, pi_n_banco integer, pi_n_proceso_electoral integer)
    	--EXECUTE 'SET search_path =' || pi_esquema; 
		EXECUTE 'SET search_path = gemma'; 
    	RETURN QUERY
    	select * from (
        select 
			ROW_NUMBER() OVER ()::INTEGER AS n_miembro_mesa_escrutinio_paginado_pk,
			mme.n_miembro_mesa_escrutinio_pk,
			mme.n_proceso_electoral ,
			mme.c_mesa ,
			mme.n_tipo_documento::integer ,
			mme.c_documento_identidad ,
			mme.c_apellido_paterno ,
			mme.c_apellido_materno ,
			mme.c_nombres ,
			mme.n_cargo::integer ,
			mme.n_ubigeo ,
			mme.n_envio_01::integer ,
			mme.n_recepcionado_01::integer ,
			mme.n_envio_02::integer ,
			pmm.n_entidad_bancaria::integer ,
			pmm.n_modalidad_pago::integer ,
			pmm.c_numero_cuenta ,
			pmm.n_billetera_digital::integer ,
			pmm.n_numero_vinculado ,
			pmm.n_activo::integer 
        from gemma.tab_miembro_mesa_escrutinio mme
		inner join gemma.tab_medio_pago_miembro_mesa pmm on (pmm.n_proceso_electoral = mme.n_proceso_electoral 
        	and pmm.c_documento_identidad = mme.c_documento_identidad)
			and pmm.n_activo = 1 
        ) rbco
		where (rbco.n_proceso_electoral = pi_n_proceso_electoral) and 
          	  (rbco.n_entidad_bancaria 	= pi_n_banco)  and
			  (rbco.n_envio_01	is null) 
       ORDER BY n_entidad_bancaria asc; 		
END;
$function$
;]]></string>
			<input_param name="pi_n_banco" jt="-1" type="integer" inOut="1" />
			<input_param name="pi_n_proceso_electoral" jt="-1" type="integer" inOut="1" />
			<input_param name="n_miembro_mesa_escrutinio_paginado_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="n_miembro_mesa_escrutinio_pk" jt="-1" type="integer" inOut="3" />
			<input_param name="n_proceso_electoral" jt="-1" type="integer" inOut="3" />
			<input_param name="c_mesa" jt="-1" type="character varying" inOut="3" />
			<input_param name="n_tipo_documento" jt="-1" type="integer" inOut="3" />
			<input_param name="c_documento_identidad" jt="-1" type="character varying" inOut="3" />
			<input_param name="c_apellido_paterno" jt="-1" type="character varying" inOut="3" />
			<input_param name="c_apellido_materno" jt="-1" type="character varying" inOut="3" />
			<input_param name="c_nombres" jt="-1" type="character varying" inOut="3" />
			<input_param name="n_cargo" jt="-1" type="integer" inOut="3" />
			<input_param name="n_ubigeo" jt="-1" type="integer" inOut="3" />
			<input_param name="n_envio_01" jt="-1" type="integer" inOut="3" />
			<input_param name="n_recepcionado_01" jt="-1" type="integer" inOut="3" />
			<input_param name="n_envio_02" jt="-1" type="integer" inOut="3" />
			<input_param name="n_entidad_bancaria" jt="-1" type="integer" inOut="3" />
			<input_param name="n_modalidad_pago" jt="-1" type="integer" inOut="3" />
			<input_param name="c_numero_cuenta" jt="-1" type="character varying" inOut="3" />
			<input_param name="n_billetera_digital" jt="-1" type="integer" inOut="3" />
			<input_param name="n_numero_vinculado" jt="-1" type="character varying" inOut="3" />
			<input_param name="n_activo" jt="-1" type="integer" inOut="3" />
		</function>
		<function name="fn_trg_insert_mm_escrutinio_seguimiento_fase1" id="ed8445f6-e57a-4fd1-9c95-ddad7018c152" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_trg_insert_mm_escrutinio_seguimiento_fase1()
 RETURNS trigger
 LANGUAGE plpgsql
AS $function$
BEGIN
    INSERT INTO gemma.tab_miembro_mesa_escrutinio_seguimiento (
        n_miembro_mesa_escrutinio,
        n_fase,
        c_aud_usuario_creacion
    )
    VALUES (
        NEW.n_miembro_mesa_escrutinio_pk,
        1,
        NEW.c_aud_usuario_creacion
    );
    RETURN NEW;
END;
$function$
;]]></string>
			<result_param jt="-1" />
		</function>
		<function name="fn_trg_insert_mm_escrutinio_seguimiento_fase2" id="2b614667-1383-4335-a76a-eb0d0b8cb4ef" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_trg_insert_mm_escrutinio_seguimiento_fase2()
 RETURNS trigger
 LANGUAGE plpgsql
AS $function$
BEGIN
  IF NEW.n_miembro_mesa_escrutinio IS NOT NULL THEN
    INSERT INTO gemma.tab_miembro_mesa_escrutinio_seguimiento (
      n_miembro_mesa_escrutinio,
      n_fase,
      c_aud_usuario_creacion
    )
    VALUES (
      NEW.n_miembro_mesa_escrutinio,
      2,                          -- Marcar fase 2 
	 NEW.c_aud_usuario_creacion
    );
  END IF;
  RETURN NEW;
END;
$function$
;]]></string>
			<result_param jt="-1" />
		</function>
		<function name="fn_trg_insert_mm_escrutinio_seguimiento_fase4" id="50c16558-1931-4f6f-bc13-0ff736b729eb" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_trg_insert_mm_escrutinio_seguimiento_fase4()
 RETURNS trigger
 LANGUAGE plpgsql
AS $function$
BEGIN
  -- Verificar si en la tabla gemma.tab_miembro_mesa_escrutinio ocurrio un UPDATE
  -- y si se actualizó los campos n_recepcionado_01 o n_archivo_recepcionado_02
  IF (TG_OP = 'UPDATE') AND (
      (NEW.n_recepcionado_01 = 1 AND (OLD.n_recepcionado_01 IS DISTINCT FROM NEW.n_recepcionado_01)) OR
      (NEW.n_recepcionado_02 = 1 AND (OLD.n_recepcionado_02 IS DISTINCT FROM NEW.n_recepcionado_02))
     )
  THEN
  -- Verifica si ya tiene marcado la fase 4
    IF NOT EXISTS(SELECT * FROM gemma.tab_miembro_mesa_escrutinio_seguimiento mme
		WHERE mme.n_miembro_mesa_escrutinio = NEW.n_miembro_mesa_escrutinio_pk AND mme.n_fase = 4) THEN
	    
		INSERT INTO gemma.tab_miembro_mesa_escrutinio_seguimiento (
    	  n_miembro_mesa_escrutinio,
	      n_fase,
    	  c_aud_usuario_creacion
    	)
	    VALUES (
    	  NEW.n_miembro_mesa_escrutinio_pk,
	      4,                    			-- Valor fijo de n_fase
    	  NEW.c_aud_usuario_creacion        -- Usuario que ejecuta
    	);
	END IF;
  END IF;
  RETURN NEW;
END;
$function$
;]]></string>
			<result_param jt="-1" />
		</function>
		<function name="fn_trg_insert_tab_ubigeo_proceso_electoral" id="61cad415-2b20-432f-b649-d33ab1a49482" isSystem="false" params_known="y" >
			<string><![CDATA[CREATE OR REPLACE FUNCTION gemma.fn_trg_insert_tab_ubigeo_proceso_electoral()
 RETURNS trigger
 LANGUAGE plpgsql
AS $function$
BEGIN  
	IF (NOT EXISTS(SELECT * FROM gemma.tab_ubigeo_proceso_electoral upe 
			WHERE upe.n_ubigeo = NEW.n_ubigeo AND upe.n_proceso_electoral =  NEW.n_proceso_electoral)) THEN
	
	    INSERT INTO gemma.tab_ubigeo_proceso_electoral(
	        n_ubigeo,
			n_proceso_electoral,
	        c_aud_usuario_creacion)
	    VALUES (
	        NEW.n_ubigeo,
	        NEW.n_proceso_electoral,
	        NEW.c_aud_usuario_creacion);
  	END IF;
  RETURN NEW;
END;
$function$
;]]></string>
			<result_param jt="-1" />
		</function>
		<trigger name="trg_insert_mm_escrutinio_seguimiento_fase1" table="tab_miembro_mesa_escrutinio" id="be80acb7-e161-45d6-990e-15c4999cf89c" isSystem="false" >
			<string><![CDATA[CREATE TRIGGER trg_insert_mm_escrutinio_seguimiento_fase1 AFTER INSERT ON gemma.tab_miembro_mesa_escrutinio FOR EACH ROW EXECUTE FUNCTION fn_trg_insert_mm_escrutinio_seguimiento_fase1()]]></string>
		</trigger>
		<trigger name="trg_insert_mm_escrutinio_seguimiento_fase2" table="tab_medio_pago_miembro_mesa" id="1c24c2fd-2f10-41a0-83d5-c0fb0758dd0c" isSystem="false" >
			<string><![CDATA[CREATE TRIGGER trg_insert_mm_escrutinio_seguimiento_fase2 AFTER INSERT ON gemma.tab_medio_pago_miembro_mesa FOR EACH ROW EXECUTE FUNCTION fn_trg_insert_mm_escrutinio_seguimiento_fase2()]]></string>
		</trigger>
		<trigger name="trg_insert_mm_escrutinio_seguimiento_fase4" table="tab_miembro_mesa_escrutinio" id="32f5ac6b-58c4-479f-a89f-df0d821ed71f" isSystem="false" >
